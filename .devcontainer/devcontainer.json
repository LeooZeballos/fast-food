{
	"name": "Java 21 & PostgreSQL",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspace",
	"customizations": {
		"vscode": {
			"extensions": [
				"vscjava.vscode-java-pack",
				"vmware.vscode-spring-boot",
				"vscjava.vscode-spring-initializr",
				"vscjava.vscode-spring-boot-dashboard",
				"ms-playwright.playwright",
				"bradlc.vscode-tailwindcss",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"dsznajder.es7-react-js-snippets"
			]
		}
	},
	"forwardPorts": [8080, 5432, 5173, 9323],
	"remoteUser": "vscode",
	"remoteEnv": {
		"GITHUB_PERSONAL_ACCESS_TOKEN": "${localEnv:GITHUB_PERSONAL_ACCESS_TOKEN}"
	},
	"onCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.gemini && mkdir -p /home/vscode/.gemini && echo '{\"/workspace\": \"TRUST_FOLDER\"}' > /home/vscode/.gemini/trustedFolders.json",
	"postCreateCommand": "cd frontend && pnpm install && npx playwright install"
}
